{
  "expo": {
    "name": "ISI BENSIN",
    "slug": "isi-bensin-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
   "android": {
  "package": "com.isibensin.app",
  "googleServicesFile": "./google-services.json",
  "usesCleartextTraffic": true,

  "config": {
    "googleMaps": {
      "apiKey": "AIzaSyBh2fpY8PiLh0yaN9CCbe0r4FPxLGswczc"
    }
  },

  "adaptiveIcon": {
    "foregroundImage": "./assets/logo.jpeg",
    "backgroundColor": "#ffffff"
  },
  "edgeToEdgeEnabled": true,
  "permissions": [
    "android.permission.RECORD_AUDIO",
    "android.permission.MODIFY_AUDIO_SETTINGS"
  ]
},
    "web": {
      "favicon": "./assets/logo.jpeg"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.jpeg",
          "color": "#ffffff",
          "sounds": [
            "./assets/alarm.wav"
          ]
        }
      ],
      "expo-font",
      "expo-asset",
      "@maplibre/maplibre-react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "8e73ce91-a044-4b51-a322-fee3004eb8c2"
      }
    },
    "owner": "ranggafebrian"
  }
}